# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database
DATABASE_URL=postgresql+asyncpg://docagent:docagent@db:5432/docagent

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-xxxxx

# Ingestion
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Critic
CRITIC_SIMILARITY_THRESHOLD=0.78
MAX_RETRIEVAL_ATTEMPTS=3

# Server
HOST=0.0.0.0
PORT=8000

# ── The model under test ──────────────────────────────────────────────────────
# Answers user queries. Any OpenAI-compatible endpoint works.
#
# Hosted (NVIDIA NIM, free tier — key from build.nvidia.com):
LLM_MODEL=deepseek-ai/deepseek-v4-flash
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=nvapi-xxxxx
#
# Local (Ollama on the host; the key is ignored but the OpenAI SDK requires one):
# LLM_MODEL=qwen3:8b
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=

# ── The evaluation judge ──────────────────────────────────────────────────────
# Used only by the RAGAS harness. Never serves user traffic.
#
# Keep this on a strong hosted model even when the model under test is local: scoring a
# model's answers with that same model measures self-consistency, not correctness.
JUDGE_MODEL=deepseek-ai/deepseek-v4-flash
JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1
JUDGE_API_KEY=nvapi-xxxxx

# Legacy single-key setting. Still honoured as the fallback for both keys above, so an
# older .env keeps working. Prefer LLM_API_KEY / JUDGE_API_KEY for new setups.
# NVIDIA_API_KEY=nvapi-xxxxx

# Database
DATABASE_URL=postgresql+asyncpg://docagent:docagent@db:5432/docagent

# Embedding model (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Ingestion
# INGESTION_STRATEGY controls how `unstructured` parses documents, and is the only switch
# that turns OCR on or off: auto (default) | fast (no OCR) | hi_res | ocr_only
INGESTION_STRATEGY=auto
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Critic
CRITIC_SIMILARITY_THRESHOLD=0.78
MAX_RETRIEVAL_ATTEMPTS=3

# Server
HOST=0.0.0.0
PORT=8000

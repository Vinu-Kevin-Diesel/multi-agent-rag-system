# NVIDIA NIM (free tier — get key from build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxx

# Database
DATABASE_URL=postgresql+asyncpg://docagent:docagent@db:5432/docagent

# Embedding model (local, no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Ingestion
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Critic
CRITIC_SIMILARITY_THRESHOLD=0.78
MAX_RETRIEVAL_ATTEMPTS=3

# Server
HOST=0.0.0.0
PORT=8000
